# PrintMRP backend — standalone-repo .gitignore
# Express + Prisma + TypeScript, deployed via PM2 on a VPS.

# ---- Secrets ----
# Never commit .env. *.example files ARE tracked so new contributors know
# which vars to set.
.env
.env.*
!.env.example
!.env.sample
!.env.production.example

# ---- PM2 runtime ----
logs/
.pm2/

# ---- Node / npm / pnpm / yarn ----
node_modules/
.npm/
.pnpm-store/
.yarn/
.pnp.*

# ---- Build output ----
dist/
build/
out/
.cache/
.turbo/

# ---- TypeScript ----
*.tsbuildinfo
.tsc-out/

# ---- Prisma ----
# The generated client lives under node_modules/@prisma/client (already
# ignored). Schema and migrations stay tracked. Ignore Prisma's local query
# logs and the `.env` Prisma sometimes drops in prisma/ (we keep it at the
# project root instead).
prisma/*.log
prisma/.env

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Coverage / tests ----
coverage/
.nyc_output/

# ---- Docker artefacts ----
# Image tarballs, build cache scratch dirs.
*.tar
*.tar.gz
.docker-compose-cache/

# ---- Database backups ----
# Don't accidentally commit a pg_dump. The exception keeps Prisma's tracked
# migration SQL files.
*.sql
!prisma/migrations/**/migration.sql

# ---- OS noise ----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editor / IDE ----
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*.swn
*~
.history/
.fleet/

# ---- Misc ----
.tmp/
.local/
*.pid
*.seed
*.pid.lock

# ---- Things to keep ----
# Belt-and-suspenders — explicitly un-ignore canonical files in case any
# upstream rule starts matching them by accident.
!README.md
!Dockerfile
!.dockerignore
