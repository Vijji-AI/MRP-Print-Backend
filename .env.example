# =============================================================================
# PrintMRP Backend — env template
# =============================================================================
# Copy this file to `.env` and fill in real values for local dev / production.
# For VPS + Supabase deployment, see `.env.production.example`.
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
#
# Local dev (docker-compose, internal Postgres):
#   postgresql://printmrp:printmrp@localhost:5432/printmrp?schema=public
#
# Supabase (recommended for VPS deploys):
#   Project Settings → Database → Connection string → URI (Session pooler)
#   Example:
#     postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres?schema=public
#
#   Use the SESSION POOLER (port 5432) — works with Prisma migrate.
#   The Transaction Pooler (port 6543) does NOT support migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/printmrp?schema=public"

# Port the API listens on. Behind nginx/Caddy this stays internal.
PORT=4000

# Production | development. Affects logging format and JWT_SECRET strictness.
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────────────
# JWT signing secret. MUST be ≥32 random chars in production.
# Generate one with:  openssl rand -hex 64
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars-long"

# Token lifetime, e.g. 7d, 12h, 30m
JWT_EXPIRES_IN="7d"

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API.
#   Dev:  http://localhost:5173,http://localhost:5174
#   Prod: https://your-frontend-domain.com
#   Wildcard (any origin, NOT recommended in prod): *
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# ── Seed admin (used by `npm run seed` / Docker startup) ────────────────────
# Idempotent: re-running updates the existing admin's password to match this.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-on-first-deploy"
SEED_ADMIN_NAME="PrintMRP Admin"

# ── Optional: SMS OTP (Aakash SMS — Nepal) ──────────────────────────────────
# Get a token from https://aakashsms.com
# Leave blank to log OTPs to the server console instead (dev mode).
# When SET, phone verification is ENFORCED on signup.
AAKASH_SMS_AUTH_TOKEN=""

# ── Optional: Vision-based sample generation ────────────────────────────────
# Powers POST /api/admin/samples/generate-from-image. Returns 503 if unset.
# Speaks OpenAI's chat-completions protocol — works with OpenAI or any
# compatible provider (e.g. Google Gemini's OpenAI-compat endpoint).
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
