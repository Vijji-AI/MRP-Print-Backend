# Copy this file to .env and fill in real values for local dev / production.

# PostgreSQL connection string.
# Local dev example:    postgresql://postgres:postgres@localhost:5432/printmrp?schema=public
# Hostinger VPS example: postgresql://printmrp:STRONG_PW@localhost:5432/printmrp?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/printmrp?schema=public"

# Port the API will listen on. Behind nginx this stays internal.
PORT=4000

# Used to sign JWT tokens. Use a long random string in production.
# Generate one with: openssl rand -hex 64
JWT_SECRET="change-me-to-a-long-random-string"

# Token lifetime, e.g. 7d, 12h
JWT_EXPIRES_IN="7d"

# Comma-separated list of origins allowed to call the API.
# In dev: http://localhost:5173
# In prod: http://YOUR-VPS-IP   (or https://your-domain.com)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# ── SMS / OTP (Aakash SMS — Nepal) ──────────────────────────────────────────
# Get your auth token from https://aakashsms.com
# Leave blank in dev — OTPs will be printed to the server console instead.
# When set, phone verification is ENFORCED on signup.
AAKASH_SMS_AUTH_TOKEN=""

# ── Seed admin credentials (used by `npm run seed`) ──────────────────────────
# Idempotent — if an admin with this email already exists, the seed no-ops.
SEED_ADMIN_EMAIL="anuj@vijji.ai"
SEED_ADMIN_PASSWORD="Vijji-Admin2026@"
SEED_ADMIN_NAME="Vijji Admin"
