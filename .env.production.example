# =============================================================================
# PrintMRP Backend — PRODUCTION env (VPS + Supabase)
# =============================================================================
# Copy this to `.env` on your VPS and fill in the placeholders.
# Never commit the filled-in version (it's gitignored).
# =============================================================================

NODE_ENV=production
PORT=4000

# ── Supabase Postgres ───────────────────────────────────────────────────────
# Direct connection (project: fvsbivelaqgewgzsfaxy).
# Replace <DB_PASSWORD> with the database password from
#   Supabase → Project Settings → Database → "Database password".
#
# NOTE: this hostname (db.<ref>.supabase.co) resolves to IPv6 only. If your
# VPS has no IPv6 (test:  curl -6 https://ifconfig.co), switch to the Session
# Pooler instead — same port 5432, works on IPv4:
#   postgresql://postgres.fvsbivelaqgewgzsfaxy:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?schema=public
# (find <REGION> in Supabase → Database → "Connection string" → Session pooler tab)
DATABASE_URL="postgresql://postgres:<DB_PASSWORD>@db.fvsbivelaqgewgzsfaxy.supabase.co:5432/postgres?schema=public"

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate on your VPS:  openssl rand -hex 64
JWT_SECRET="<paste-64-byte-hex-here>"
JWT_EXPIRES_IN="7d"

# ── CORS ────────────────────────────────────────────────────────────────────
# Set this to your actual frontend origin(s). No wildcards in production.
CORS_ORIGINS="https://your-frontend-domain.com"

# ── Initial admin (created on first boot via `node prisma/seed.cjs`) ────────
SEED_ADMIN_EMAIL="anuj@vijji.ai"
SEED_ADMIN_PASSWORD="<long-random-password>"
SEED_ADMIN_NAME="Vijji Admin"

# ── Optional integrations (leave blank to disable) ──────────────────────────
AAKASH_SMS_AUTH_TOKEN=""
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
